[
  {
    "type": "Dropdown",
    "name": "version",
    "description": "Reference Printables revision",
    "range": "",
    "options": "mk3,mk2_2,mk2_1,mk2_0",
    "defaultValue": "mk3",
    "editMode": false
  },
  {
    "type": "Dropdown",
    "name": "part",
    "description": "Reference STL part or assembled scene",
    "range": "",
    "options": [
      {
        "value": "assembly",
        "label": "assembly"
      },
      {
        "value": "base",
        "label": "base"
      },
      {
        "value": "cap",
        "label": "cap",
        "visibleWhen": {
          "field": "version",
          "operator": "equals",
          "value": "mk3"
        }
      },
      {
        "value": "lensHolder",
        "label": "lensHolder",
        "visibleWhen": {
          "field": "version",
          "operator": "equals",
          "value": "mk3"
        }
      },
      {
        "value": "straightener",
        "label": "straightener",
        "visibleWhen": {
          "field": "version",
          "operator": "equals",
          "value": "mk3"
        }
      },
      {
        "value": "diffuser",
        "label": "diffuser",
        "visibleWhen": {
          "field": "version",
          "operator": "equals",
          "value": "mk3"
        }
      },
      {
        "value": "lens",
        "label": "lens"
      }
    ],
    "defaultValue": "assembly",
    "editMode": false
  },
  {
    "type": "Dropdown",
    "name": "baseVariant",
    "description": "Base STL variant",
    "range": "",
    "options": [
      {
        "value": "gardena",
        "label": "gardena"
      },
      {
        "value": "threeQuarterGht",
        "label": "threeQuarterGht",
        "visibleWhen": {
          "field": "version",
          "operator": "in",
          "values": ["mk3", "mk2_2", "mk2_1"]
        }
      },
      {
        "value": "threeQuarterNpt",
        "label": "threeQuarterNpt",
        "visibleWhen": {
          "field": "version",
          "operator": "equals",
          "value": "mk2_0"
        }
      }
    ],
    "defaultValue": "gardena",
    "editMode": false
  },
  {
    "type": "Slider",
    "name": "explode",
    "description": "Separate assembled STL parts for inspection",
    "range": "0,1,0.01",
    "defaultValue": "0",
    "updateMode": "transform",
    "visibleWhen": {
      "field": "version",
      "operator": "equals",
      "value": "mk3"
    },
    "editMode": false
  },
  {
    "type": "Checkbox",
    "name": "showStages",
    "description": "Show the internal stage STL parts in assembly mode",
    "defaultValue": true,
    "visibleWhen": {
      "field": "version",
      "operator": "equals",
      "value": "mk3"
    },
    "editMode": false
  }
]
